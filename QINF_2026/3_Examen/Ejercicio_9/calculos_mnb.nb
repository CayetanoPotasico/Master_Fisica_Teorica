Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Definimos", " ", "la", " ", "base", " ", "de", " ", "Pauli"}], ",", 
    RowBox[{"incluyendo", " ", "la", " ", "Identidad"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Sigma]", "[", "0", "]"}], "=", 
     RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Sigma]", "[", "1", "]"}], "=", 
     RowBox[{"PauliMatrix", "[", "1", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Sigma]", "[", "2", "]"}], "=", 
     RowBox[{"PauliMatrix", "[", "2", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Sigma]", "[", "3", "]"}], "=", 
     RowBox[{"PauliMatrix", "[", "3", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Definimos", " ", "nuestro", " ", "operador", " ", "L", " ", "especifico",
      " ", "del", " ", "problema"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"L", "=", 
       RowBox[{
        RowBox[{"Sqrt", "[", "\[Gamma]", "]"}], "|", "-"}]}], 
      "\[RightAngleBracket]"}], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"+", "|"}]}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Donde", "|", "-"}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}]}], "}"}], " ", "y", " ", 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        RowBox[{"+", "|"}], " ", "=", 
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}], 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}]}]}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Sqrt", "[", "\[Gamma]", "]"}], "/", "2"}], ")"}], "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", 
          RowBox[{"-", "1"}]}], "}"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "1.", " ", "Calculamos", " ", "los", " ", "coeficientes", " ", "l_i", " ", 
     RowBox[{"(", 
      RowBox[{"l1", ",", "l2", ",", "l3"}], ")"}], " ", "proyectando", " ", 
     "L", " ", "en", " ", "la", " ", "base", " ", "de", " ", "Pauli"}], 
    "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "No", " ", "necesitamos", " ", "l_", "0", " ", "porque", " ", "la", " ", 
     "Identidad", " ", "no", " ", "contribuye", " ", "a", " ", "la", " ", 
     "disipacion", " ", "en", " ", "la", " ", "ec", " ", "de", " ", 
     "Lindblad"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lvec", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "2"}], "*", 
        RowBox[{"Tr", "[", 
         RowBox[{"L", ".", 
          RowBox[{"\[Sigma]", "[", "i", "]"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Vector de coeficientes l_i: \>\"", ",", "lvec"}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "2.", " ", "Construimos", " ", "la", " ", "Matriz", " ", "de", " ", 
      "Kossakowski", " ", "A_ij"}], "=", 
     RowBox[{"l_i", "*", 
      RowBox[{"Conjugate", "[", "l_j", "]"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"A", "=", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lvec", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"lvec", "[", 
           RowBox[{"[", "j", "]"}], "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], "//", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{"#", ",", 
         RowBox[{"\[Gamma]", ">", "0"}]}], "]"}], "&"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Matriz A_ij:\>\"", "]"}], ";"}], "\n", 
   RowBox[{"MatrixForm", "[", "A", "]"}]}]}]], "Input",
